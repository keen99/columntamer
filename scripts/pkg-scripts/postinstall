#!/bin/bash
# postinstall: bootstrap menu LaunchAgent + restart Finder if user agreed.
# Helper folded into menu (NSTimer poll). No shell helper, no helper LaunchAgent.
set -e

LOG=/tmp/columntamer-postinstall.log
log() { echo "$(date '+%H:%M:%S') $*" >>"$LOG"; }
trap 'rc=$?; log "EXIT rc=$rc (line $LINENO)"' EXIT
log "=== postinstall start (pid $$) ==="
log "args: $*"
log "caller uid=$(id -u) user=$(id -un)"

MENU_PLIST="/Library/LaunchAgents/columntamer.menu.plist"
LEGACY_APPROOT="/Library/Application Support/ColumnTamer"
FLAG="/var/run/.columntamer.restart"

# Remove legacy approot from pre-rehome installs (menu now in /Applications).
# osax stays in /Library/ScriptingAdditions (Finder load path, required).
rm -rf "$LEGACY_APPROOT"

# M6: pin ownership to root:wheel (installer runs as root; staged files
# otherwise may carry dev-user ownership = persistence vector).
chown -R root:wheel "/Library/ScriptingAdditions/ColumnTamer.osax"
# Menu in /Applications = user:admin (drag-install standard, match XtraFinder).
# No root:wheel (non-standard for /Applications).
# osax stays root:wheel (system path).
chown root:wheel "$MENU_PLIST" 2>/dev/null || true

CONSOLE_USER="$(stat -f%Su /dev/console 2>/dev/null || true)"
CONSOLE_UID="$(id -u "$CONSOLE_USER" 2>/dev/null || true)"
log "detected CONSOLE_USER=$CONSOLE_USER CONSOLE_UID=$CONSOLE_UID"

# Sweep legacy helper artifacts (pre-fold installs shipped shell helper +
# LaunchAgent). Kill stray helper procs, remove plist, bootout if registered.
pkill -f "ColumnTamerHelper" 2>/dev/null || true
rm -f "$LEGACY_APPROOT/ColumnTamerHelper"
rm -f "/Library/LaunchAgents/columntamer.helper.plist"
if [[ -n "$CONSOLE_UID" ]]; then
  launchctl asuser "$CONSOLE_UID" -- launchctl bootout \
    "gui/$CONSOLE_UID/columntamer.helper" 2>/dev/null || true
fi

# Stop menu LaunchAgent + kill strays before relaunch (no respawn race).
if [[ -n "$CONSOLE_UID" ]]; then
  launchctl asuser "$CONSOLE_UID" -- launchctl bootout \
    "gui/$CONSOLE_UID/columntamer.menu" 2>/dev/null || true
fi
pkill -f "ColumnTamerMenu" 2>/dev/null || true

# Bridge current session. LaunchAgent owns future login/restart.
# menu: `open` .app (LaunchServices). KeepAlive=false — user Quit respected
# (menu = UI + reinject poll, osax independent).
if [[ -n "$CONSOLE_UID" ]]; then
  log "opening menu..."
  open "/Applications/ColumnTamerMenu.app" 2>/dev/null || true
  log "menu open done"
  log "ps after launch: $(ps ax | grep -i ColumnTamer | grep -v grep | tr '\n' '|')"
fi

# restart only if user agreed at preinstall prompt
if [[ -f "$FLAG" ]]; then
  log "killall Finder (flag set)..."
  killall Finder 2>/dev/null || true
  log "killall Finder done"
  rm -f "$FLAG"
else
  log "no restart flag"
  if [[ -n "$CONSOLE_UID" ]]; then
    launchctl asuser "$CONSOLE_UID" osascript -e \
      'display notification "ColumnTamer installed. Restart Finder to activate." with title "ColumnTamer"' \
      2>/dev/null || true
  fi
fi

log "postinstall end"
exit 0
